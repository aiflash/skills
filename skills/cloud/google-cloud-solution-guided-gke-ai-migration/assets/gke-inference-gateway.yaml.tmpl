apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: {workload_name}-gateway
  namespace: {namespace}
spec:
  gatewayClassName: gke-l7-rilb  # regional internal ALB; see SKILL.md before changing
  listeners:
  - name: http
    protocol: HTTP
    port: 80
---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {workload_name}-route
  namespace: {namespace}
spec:
  parentRefs:
  - name: {workload_name}-gateway
  rules:
  - matches:
    - path:
        type: PathPrefix
        value: /v1
    backendRefs:
    - name: {workload_name}-vllm-svc
      port: 8000
